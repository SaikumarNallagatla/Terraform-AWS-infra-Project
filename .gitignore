# Terraform working directories
**/.terraform/*

# Terraform state and crash files
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Variable files may contain credentials or account-specific values
*.tfvars
*.tfvars.json

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editor and operating-system files
.vscode/
.idea/
.DS_Store
Thumbs.db
